# Local dev — meta-repo stack (deploy/docker-compose.yml) or standalone Postgres.
SERVICE_NAME=contract-management
PORT=4103
ENVIRONMENT=development
GIN_MODE=debug

DATABASE_URL=postgres://svc_iag_contracts:iag_contracts_dev@localhost:5432/iag_platform?sslmode=disable

JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
AUDIENCE=iag.contract-management

SERVICE_CLIENT_ID=iag-contract-management
SERVICE_CLIENT_SECRET=dev-contracts-secret-bootstrap
AUTH_TOKEN_URL=http://localhost:3001/oauth/token

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Migrations run automatically on startup (embedded SQL in persistence.Connect).
