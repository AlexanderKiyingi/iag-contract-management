# Production — contract management API (JWT verified locally; ingress via iag-api-gateway).
ENVIRONMENT=production
SERVICE_NAME=contract-management
PORT=4103
GIN_MODE=release

# Railway: health checks probe PORT; do not set ADDR unless it matches PORT.
DATABASE_URL=postgres://svc_iag_contracts:PASSWORD@HOST:5432/iag_platform?sslmode=require

JWT_ISSUER=https://auth.example.com
JWKS_URL=https://auth.example.com/.well-known/jwks.json
AUDIENCE=iag.contract-management

SERVICE_CLIENT_ID=iag-contract-management
SERVICE_CLIENT_SECRET=change-me-in-production-min-16-chars
AUTH_TOKEN_URL=https://auth.example.com/oauth/token

# Comma-separated browser origins for CORS (required in production).
ALLOWED_ORIGINS=https://app.example.com

# Gateway / load-balancer CIDRs so ClientIP() and rate limits see real clients.
# TRUSTED_PROXIES=10.0.0.0/8

OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317

EVENT_BUS_ENABLED=true
KAFKA_BROKERS=kafka-broker-1:9092,kafka-broker-2:9092
NOTIFY_DEFAULT_RECIPIENT=ops@example.com
NOTIFY_CHANNEL=email
TEMPLATE_CONTRACTS_ASSISTANCE=contracts-assistance-requested
TEMPLATE_CONTRACTS_MILESTONE_DUE=contracts-milestone-due-soon
MILESTONE_REMINDER_DAYS=7

REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_PER_MINUTE=120
SHUTDOWN_TIMEOUT_SECONDS=15
