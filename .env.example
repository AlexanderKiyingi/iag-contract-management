# Local development — copy to `.env` in this directory.
# Production template: config/.env.production.example

SERVICE_NAME=contract-management
PORT=4103
ENVIRONMENT=development
GIN_MODE=debug

DATABASE_URL=postgres://svc_iag_contracts:iag_contracts_dev@localhost:5432/iag_platform?sslmode=disable

JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
AUDIENCE=iag.contract-management

SERVICE_CLIENT_ID=iag-contract-management
SERVICE_CLIENT_SECRET=dev-contracts-secret-bootstrap
AUTH_TOKEN_URL=http://localhost:3001/oauth/token

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional — gateway/load-balancer CIDRs for correct client IP behind proxy
# TRUSTED_PROXIES=10.0.0.0/8

# Optional tuning
# REQUEST_TIMEOUT_SECONDS=30
# READ_TIMEOUT_SECONDS=15
# WRITE_TIMEOUT_SECONDS=30
# RATE_LIMIT_PER_MINUTE=120
# MAX_BODY_BYTES=8388608
# SHUTDOWN_TIMEOUT_SECONDS=15

# OpenTelemetry — empty disables OTel
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# APP_ENV=development

# Migrations run automatically on startup (embedded SQL in persistence.Connect).

# Kafka domain events (iag.commercial) — optional
EVENT_BUS_ENABLED=true
KAFKA_BROKERS=localhost:19092

# Alert dispatch via contracts.alert.raised → iag-notifications
NOTIFY_DEFAULT_RECIPIENT=ops@iag.local
NOTIFY_CHANNEL=email
TEMPLATE_CONTRACTS_ASSISTANCE=contracts-assistance-requested
TEMPLATE_CONTRACTS_MILESTONE_DUE=contracts-milestone-due-soon

# Jobs CLI (cmd/jobs): MILESTONE_REMINDER_DAYS=7
